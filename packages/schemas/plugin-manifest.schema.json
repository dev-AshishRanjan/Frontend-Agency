{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontend-agency.local/schemas/plugin-manifest.schema.json",
  "title": "Frontend Agency Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "description", "author", "skills", "interface"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "license": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "const": "./skills/"
    },
    "interface": {
      "type": "object",
      "required": ["displayName", "shortDescription", "longDescription", "developerName", "category"],
      "properties": {
        "displayName": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "longDescription": {
          "type": "string"
        },
        "developerName": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      }
    }
  }
}
