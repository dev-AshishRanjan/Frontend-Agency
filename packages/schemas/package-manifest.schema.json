{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontend-agency.local/schemas/package-manifest.schema.json",
  "title": "Frontend Agency Package Manifest",
  "type": "object",
  "required": ["name", "plugin", "version", "marketplace", "pluginRoot", "generatedAt", "files"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "plugin": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "marketplace": {
      "const": ".agents/plugins/marketplace.json"
    },
    "pluginRoot": {
      "type": "string",
      "pattern": "^plugins/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
