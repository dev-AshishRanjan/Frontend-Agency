{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontend-agency.local/schemas/skill-eval.schema.json",
  "title": "Frontend Agency Skill Eval",
  "type": "object",
  "required": [
    "skill",
    "intent",
    "trigger_terms",
    "expected_sections",
    "rejection_patterns",
    "sample_requests"
  ],
  "additionalProperties": false,
  "properties": {
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "intent": {
      "type": "string",
      "minLength": 30
    },
    "trigger_terms": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "expected_sections": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "rejection_patterns": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "sample_requests": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 20
      }
    }
  }
}
