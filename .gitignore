dist/

# Logs and temp files
*.log
*.tmp

# Local research inputs (not product artifacts)
Chat History.txt
Executive Summary.pdf

# NOTE: .claude/ is intentionally NOT ignored.
# .claude/commands/ contains slash commands that must be committed
# so teams can share them via Git and the npm package ships them.
