{
  "name": "frontend-agency",
  "version": "1.0.0",
  "description": "Agency-grade frontend skills for AI agents. Plan, design, build, review, and harden premium frontend experiences.",
  "author": "Frontend Agency",
  "license": "MIT",
  "homepage": "https://github.com/frontend-agency/frontend-agency#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontend-agency/frontend-agency.git"
  },
  "bugs": {
    "url": "https://github.com/frontend-agency/frontend-agency/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "frontend-agency": "bin/install.mjs"
  },
  "files": [
    "bin/",
    "CLAUDE.md",
    ".claude/",
    "plugins/",
    "LICENSE",
    "INSTALL.md"
  ],
  "scripts": {
    "validate": "node scripts/validate-repo.mjs",
    "eval:skills": "node scripts/run-skill-evals.mjs",
    "package:plugin": "node scripts/package-plugin.mjs",
    "release:check": "node scripts/release-check.mjs",
    "compile:adapters": "node scripts/compile-adapters.mjs",
    "pack": "npm pack --dry-run"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "frontend",
    "design-systems",
    "accessibility",
    "performance",
    "ai",
    "skills",
    "cursor",
    "gemini"
  ]
}
